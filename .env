# ==========================================
# MES Framework - Docker Environment
# ==========================================

# PostgreSQL
POSTGRES_DB=mes_db
POSTGRES_USER=mes_user
POSTGRES_PASSWORD=Mes@2026!
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_DEFAULT_USER=mes_user
RABBITMQ_DEFAULT_PASS=Mes@2026!
RABBITMQ_ERLANG_COOKIE=MES_RABBIT_COOKIE_2026
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Connection Strings (for reference)
MES_DB_CONNECTION=Host=localhost;Port=5432;Database=mes_db;Username=mes_user;Password=Mes@2026!
MES_REDIS_CONNECTION=localhost:6379
MES_RABBITMQ_CONNECTION=amqp://mes_user:Mes@2026!@localhost:5672/
