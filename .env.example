# ============================================
# MES Framework - 环境变量模板
# 复制本文件为 .env 并填入真实值
# cp .env.example .env
# ============================================

# ---------- PostgreSQL ----------
POSTGRES_HOST=mes-postgres
POSTGRES_PORT=5432
POSTGRES_DB=mes_db
POSTGRES_USER=mes_user
POSTGRES_PASSWORD=          # 必填：PostgreSQL 密码

# ---------- Redis ----------
REDIS_HOST=mes-redis
REDIS_PORT=6379
REDIS_PASSWORD=             # 可选：Redis 密码（默认无密码）

# ---------- RabbitMQ ----------
RABBITMQ_HOST=mes-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_DEFAULT_USER=mes_user
RABBITMQ_DEFAULT_PASS=      # 必填：RabbitMQ 密码
RABBITMQ_ERLANG_COOKIE=     # 必填：Erlang Cookie（集群节点间通信）

# ---------- MES API ----------
JWT_SECRET_KEY=             # 必填：JWT 签名密钥（至少 32 字符）
JWT_ISSUER=MES-Framework
JWT_AUDIENCE=MES-Users
JWT_EXPIRY_HOURS=8
